// Prisma Schema — News Feed System
// Source of truth: PostgreSQL
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id             String   @id @default(cuid())
  username       String   @unique
  email          String   @unique
  passwordHash   String
  displayName    String?
  bio            String?
  avatarUrl      String?
  // Denormalized counters — avoid COUNT(*) on hot paths
  followerCount  Int      @default(0)
  followingCount Int      @default(0)
  // Celebrity flag: set true when followerCount >= CELEBRITY_THRESHOLD
  // Celebrity posts skip fanout-on-write; merged at read time instead
  isCelebrity    Boolean  @default(false)
  // Hashed refresh token stored for invalidation on logout
  refreshToken   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posts         Post[]
  likes         Like[]
  comments      Comment[]
  followers     Follow[]       @relation("Following")
  following     Follow[]       @relation("Follower")
  notifications Notification[]
  feedItems     FeedItem[]

  @@index([username])
  @@index([createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────
// POST
// ─────────────────────────────────────────────
model Post {
  id            String   @id @default(cuid())
  content       String   @db.Text
  authorId      String
  // Denormalized counters for fast display without joins
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     Like[]
  comments  Comment[]
  feedItems FeedItem[]

  // Compound index: profile feed queries (posts by author, sorted by time)
  @@index([authorId, createdAt(sort: Desc)])
  // Global recency index: used in celebrity post merge at read time
  @@index([createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────
// FOLLOW
// ─────────────────────────────────────────────
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  // Unique constraint prevents duplicate follows (idempotent)
  @@unique([followerId, followingId])
  // Who does this user follow? (fanout worker query)
  @@index([followerId])
  // Who follows this user? (follower list query)
  @@index([followingId])
}

// ─────────────────────────────────────────────
// LIKE
// ─────────────────────────────────────────────
model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Unique constraint: idempotent likes (like twice = same result)
  @@unique([userId, postId])
  @@index([postId])
}

// ─────────────────────────────────────────────
// COMMENT
// ─────────────────────────────────────────────
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  postId    String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Comments on a post, sorted by time (main query pattern)
  @@index([postId, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String           // recipient
  actorId   String           // who triggered the notification
  type      NotificationType
  postId    String?          // relevant post (nullable for FOLLOW type)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unread count query + paginated notification list
  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
}

enum NotificationType {
  FOLLOW
  LIKE
  COMMENT
  MENTION
}

// ─────────────────────────────────────────────
// FEED ITEM (Materialized Timeline)
// ─────────────────────────────────────────────
model FeedItem {
  id        String   @id @default(cuid())
  userId    String   // timeline owner (follower)
  postId    String   // post that appears in their feed
  authorId  String   // post author (for celebrity merge filtering)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Prevent duplicate feed items (idempotent fanout)
  @@unique([userId, postId])
  // Primary read path: get user's feed sorted by time
  @@index([userId, createdAt(sort: Desc)])
}
